<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Dublin Core elements stub.

  opc-coreProperties.xsd imports the full Dublin Core schema from
  http://dublincore.org/... but the ECMA-376 schema bundle doesn't
  ship a local copy, and xmllint-wasm can't fetch URLs. This stub
  declares only the dc:* elements that opc-coreProperties.xsd
  references, typed loosely (xs:anyType) so the schema compiles and
  docProps/core.xml validates against the OPC structure.

  Hand-written for this project; not derived from any specific
  upstream copy. SPDX-License-Identifier: CC0-1.0
-->
<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  targetNamespace="http://purl.org/dc/elements/1.1/"
  elementFormDefault="qualified">
  <xs:element name="creator" type="xs:anyType"/>
  <xs:element name="description" type="xs:anyType"/>
  <xs:element name="identifier" type="xs:anyType"/>
  <xs:element name="language" type="xs:anyType"/>
  <xs:element name="subject" type="xs:anyType"/>
  <xs:element name="title" type="xs:anyType"/>
  <xs:element name="type" type="xs:anyType"/>
</xs:schema>
