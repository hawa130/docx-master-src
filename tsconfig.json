{
  "compilerOptions": {
    // Environment setup & latest features.
    // DOM is needed for the Document / Element type globals used throughout
    // src/core/ — @xmldom/xmldom returns DOM-compatible objects and the code
    // types them by structure. We never run in a browser, so the runtime
    // globals from this lib are inert; we only consume the type definitions.
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "paths": {
      "@core/*": ["./src/core/*"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
